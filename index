<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>凱翔 & 禹萱 Wedding</title>
    <link href="https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&family=Noto+Serif+TC:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --text-color: #2c3e50;
            --accent-color: #5d6d7e;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body, html {
            height: 100%;
            background-color: #fdfdfd; /* 配合圖片底色 */
            font-family: 'Noto Serif TC', serif;
        }

        /* 主容器：確保內容垂直水平置中 */
        .main-container {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            width: 100%;
            position: relative;
            background: url('main-background.png') no-repeat center center/contain; 
            /* 備註：請將你的附圖命名為 main-background.png 上傳到 GitHub */
            padding: 40px 20px;
            text-align: center;
        }

        /* 歡迎標題 (手寫風) */
        .welcome-text {
            font-family: 'Ma Shan Zheng', cursive;
            font-size: 4rem;
            color: var(--text-color);
            margin-bottom: 20px;
        }

        /* 日期 */
        .date-text {
            font-size: 1.5rem;
            letter-spacing: 5px;
            margin-bottom: 30px;
            font-weight: 300;
        }

        /* 名字與標語 */
        .names {
            font-family: 'Ma Shan Zheng', cursive;
            font-size: 2rem;
            margin-top: 20px;
        }

        .tagline {
            font-size: 1.4rem;
            letter-spacing: 3px;
            margin-top: 10px;
        }

        /* 按鈕預留位置 (稍後你會補充需求，我先做個簡單的跳轉按鈕) */
        .enter-button {
            margin-top: 50px;
            padding: 12px 40px;
            background-color: rgba(255, 255, 255, 0.8);
            border: 1px solid var(--accent-color);
            color: var(--text-color);
            text-decoration: none;
            border-radius: 30px;
            font-size: 1.1rem;
            transition: 0.3s;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        .enter-button:hover {
            background-color: var(--accent-color);
            color: white;
            letter-spacing: 2px;
        }

        /* 響應式調整 */
        @media (max-width: 600px) {
            .welcome-text { font-size: 2.8rem; }
            .date-text { font-size: 1.2rem; }
            .main-container { background-size: cover; } /* 手機端圖片鋪滿 */
        }
    </style>
</head>
<body>

    <div class="main-container">
        <h1 class="welcome-text">歡迎來參加</h1>
        
        <div class="date-text">10 - 10 - 2026</div>

        <div class="names">凱翔與禹萱</div>
        <div class="tagline">我們要結婚了！</div>

        <a href="schedule" class="enter-button">點擊進入</a>
    </div>

</body>
</html>
